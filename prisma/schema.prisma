// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id            String   @id @default(cuid())
  username      String   @unique
  password      String
  name          String?
  email         String?
  role          String   @default("admin") // president, general_secretary, treasurer, deputy, admin
  positionAr    String?  // المنصب بالعربية
  positionFr    String?  // المنصب بالفرنسية
  permissions   String?  // صلاحيات مفصولة بفاصلة: all, news, members, documents, messages, reports, finance, settings
  photo         String?  // صورة العضو
  phone         String?  // رقم الهاتف
  lastLogin     DateTime?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Executive Messages (الرسائل الداخلية بين أعضاء المكتب)
model ExecutiveMessage {
  id          String   @id @default(cuid())
  senderId    String
  receiverId  String?  // null يعني رسالة للجميع
  subject     String
  message     String
  type        String   @default("message") // message, news, file, invitation, photo
  fileUrl     String?  // رابط الملف إذا كان نوع الملف
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Delegations (تفويض الصلاحيات)
model Delegation {
  id          String   @id @default(cuid())
  fromUserId  String   // من (الرئيس عادة)
  toUserId    String   // إلى (النائب)
  permission  String   // الصلاحية المفوضة
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Partner {
  id          String   @id @default(cuid())
  nameAr      String
  nameFr      String
  descriptionAr String?
  descriptionFr String?
  logo        String?
  website     String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model News {
  id          String   @id @default(cuid())
  titleAr     String
  titleFr     String
  contentAr   String
  contentFr   String
  date        DateTime @default(now())
  image       String?
  featured    Boolean  @default(false)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id          String   @id @default(cuid())
  titleAr     String
  titleFr     String
  descriptionAr String
  descriptionFr String
  icon        String   @default("Heart")
  color       String   @default("emerald")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  valueAr   String?
  valueFr   String?
  value     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Stat {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  labelAr   String
  labelFr   String
  icon      String   @default("Users")
  order     Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Board Members (أعضاء المكتب المسير - للعرض)
model BoardMember {
  id          String   @id @default(cuid())
  nameAr      String
  nameFr      String
  titleAr     String
  titleFr     String
  photo       String?
  bioAr       String?
  bioFr       String?
  email       String?
  phone       String?
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Committees (اللجن)
model Committee {
  id          String   @id @default(cuid())
  nameAr      String
  nameFr      String
  descriptionAr String?
  descriptionFr String?
  icon        String   @default("Users")
  color       String   @default("emerald")
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     CommitteeMember[]
}

// Committee Members
model CommitteeMember {
  id          String   @id @default(cuid())
  committeeId String
  nameAr      String
  nameFr      String
  titleAr     String?
  titleFr     String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  committee   Committee @relation(fields: [committeeId], references: [id], onDelete: Cascade)
}

// Association Members (المنخرطين)
model Member {
  id              String   @id @default(cuid())
  memberNumber    String   @unique
  nationalId      String   @unique  // رقم البطاقة الوطنية
  password        String
  nameAr          String
  nameFr          String?
  email           String?
  phone           String?
  whatsapp        String?  // رقم الواتساب
  department      String?
  joinDate        DateTime @default(now())
  active          Boolean  @default(true)
  firstLogin      Boolean  @default(true)  // هل هو أول دخول؟
  mustChangePassword Boolean @default(true)  // يجب تغيير كلمة المرور
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  requests        ServiceRequest[]
  messages        MemberMessage[]
}

// Service Requests
model ServiceRequest {
  id          String   @id @default(cuid())
  memberId    String
  serviceId   String?
  titleAr     String
  titleFr     String
  descriptionAr String
  descriptionFr String?
  status      String   @default("pending") // pending, approved, rejected, completed
  priority    String   @default("normal")  // low, normal, high, urgent
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// Member Messages to Board
model MemberMessage {
  id          String   @id @default(cuid())
  memberId    String
  subject     String
  message     String
  reply       String?
  read        Boolean  @default(false)
  replied     Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

// Notification Settings for WhatsApp
model NotificationSetting {
  id            String   @id @default(cuid())
  key           String   @unique
  value         String?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Notification Logs
model NotificationLog {
  id          String   @id @default(cuid())
  memberId    String?
  type        String   // request_update, message_reply, new_message
  channel     String   // whatsapp, sms, email
  status      String   // pending, sent, failed
  message     String
  error       String?
  createdAt   DateTime @default(now())
}

// Social Media Settings for publishing
model SocialMediaSetting {
  id            String   @id @default(cuid())
  platform      String   @unique // facebook, instagram, twitter, telegram
  enabled       Boolean  @default(false)
  accessToken   String?  // API access token
  apiKey        String?  // API key if needed
  apiSecret     String?  // API secret if needed
  pageId        String?  // Facebook Page ID or Instagram Business Account ID
  webhookUrl    String?  // Webhook URL for platforms that support it
  username      String?  // Username for the platform
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Social Media Publishing Logs
model SocialPublishLog {
  id          String   @id @default(cuid())
  newsId      String?  // Reference to the news article
  platform    String   // facebook, instagram, twitter, telegram
  status      String   // success, failed, pending
  postId      String?  // ID of the post on the social platform
  postUrl     String?  // URL to the published post
  message     String   // The message that was published
  error       String?  // Error message if failed
  createdAt   DateTime @default(now())
}

// Documents (المستندات)
model Document {
  id                String   @id @default(cuid())
  titleAr           String
  titleFr           String
  descriptionAr     String?
  descriptionFr     String?
  category          String   @default("general") // general, financial, administrative, legal
  fileUrl           String
  fileType          String   @default("pdf") // pdf, doc, xls, etc.
  fileSize          Int?
  downloadCount     Int      @default(0)
  order             Int      @default(0)
  active            Boolean  @default(true)
  // حقول التخصيص والظهور
  visibilityType    String   @default("all") // all, bureau, members, committee_presidents, specific_member, specific_admin
  visibleToMemberIds String? // معرفات الأعضاء المحددين (مفصولة بفاصلة)
  visibleToAdminIds  String? // معرفات أعضاء المكتب المحددين (مفصولة بفاصلة)
  visibleToCommitteeIds String? // معرفات اللجن المحددة (مفصولة بفاصلة)
  uploadedBy        String?  // معرف من رفع المستند
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Announcements (الإعلانات والتنبيهات)
model Announcement {
  id          String   @id @default(cuid())
  titleAr     String
  titleFr     String
  contentAr   String
  contentFr   String
  type        String   @default("info") // info, warning, success, urgent
  targetType  String   @default("all") // all, visitors, members, bureau, committees
  documentId  String?  // مستند مرفق اختياري
  senderId    String?  // المرسل (من أعضاء المكتب)
  active      Boolean  @default(true)
  expiresAt   DateTime? // تاريخ انتهاء الإعلان
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Announcement Reads (تتبع قراءة الإعلانات)
model AnnouncementRead {
  id              String   @id @default(cuid())
  announcementId  String
  memberId        String?  // للمنخرطين
  sessionId       String?  // للزوار
  readAt          DateTime @default(now())
}
